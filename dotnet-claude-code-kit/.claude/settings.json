{
  "$comment": "Project-shared Claude Code settings for .NET solutions. Hooks assume jq and the dotnet SDK are on PATH (on Windows, use Git Bash). Adjust permission rules to your team's risk tolerance.",
  "permissions": {
    "allow": [
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(dotnet format*)",
      "Bash(dotnet restore*)",
      "Bash(dotnet list *)",
      "Bash(dotnet ef migrations list*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Read(**/appsettings.Production.json)",
      "Read(**/*.pfx)",
      "Read(**/secrets.json)",
      "Bash(dotnet ef database drop*)",
      "Bash(git push --force*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-paths.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dotnet-post-write.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-on-stop.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
